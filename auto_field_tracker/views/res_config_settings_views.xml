<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Quick shortcut in Technical menu under Settings -->
    <record id="action_settings_field_tracker" model="ir.actions.act_window">
        <field name="name">Auto Field Trackers</field>
        <field name="res_model">field.tracker.config</field>
        <field name="view_mode">tree,form</field>
        <field name="groups_id" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <menuitem id="menu_settings_field_tracker"
              name="Auto Field Tracker"
              parent="base.menu_custom"
              action="action_settings_field_tracker"
              sequence="100"
              groups="base.group_system"/>
</odoo>
