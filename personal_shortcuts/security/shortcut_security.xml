<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="personal_shortcut_own_rule" model="ir.rule">
        <field name="name">Personal Shortcut: own records</field>
        <field name="model_id" ref="model_personal_shortcut"/>
        <field name="domain_force">[("user_id", "=", user.id)]</field>
        <field name="groups" eval="[Command.link(ref('base.group_user'))]"/>
    </record>

    <record id="personal_shortcut_admin_rule" model="ir.rule">
        <field name="name">Personal Shortcut: administrators</field>
        <field name="model_id" ref="model_personal_shortcut"/>
        <field name="domain_force">[(1, "=", 1)]</field>
        <field name="groups" eval="[Command.link(ref('base.group_system'))]"/>
    </record>
</odoo>
