<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1600 900" role="img" aria-labelledby="title desc">
  <title id="title">Easy Switch Login banner</title>
  <desc id="desc">Banner for the Easy Switch Login Odoo module with admin switch, user picker, and switch back highlights.</desc>
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#13233f"/>
      <stop offset="100%" stop-color="#1f3a63"/>
    </linearGradient>
    <linearGradient id="accent" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#8c6a86"/>
      <stop offset="100%" stop-color="#77506f"/>
    </linearGradient>
    <linearGradient id="back" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#d08a34"/>
      <stop offset="100%" stop-color="#a9601f"/>
    </linearGradient>
  </defs>

  <rect width="1600" height="900" fill="url(#bg)"/>
  <circle cx="1320" cy="120" r="180" fill="#ffffff0f"/>
  <circle cx="1430" cy="770" r="210" fill="#ffffff08"/>
  <circle cx="180" cy="760" r="140" fill="#ffffff08"/>

  <rect x="78" y="84" width="168" height="168" rx="36" fill="#ffffff14" stroke="#ffffff2c"/>
  <circle cx="162" cy="146" r="28" fill="#fff"/>
  <path d="M117 214c10-29 33-44 45-44s35 15 45 44" fill="none" stroke="#d08a34" stroke-width="20" stroke-linecap="round"/>

  <text x="288" y="140" fill="#ffffff" font-size="62" font-family="Arial, sans-serif" font-weight="700">EASY SWITCH LOGIN</text>
  <text x="288" y="198" fill="#d9e4f5" font-size="30" font-family="Arial, sans-serif">Admin systray user switching for Odoo 19</text>

  <g transform="translate(288 242)">
    <rect width="178" height="42" rx="21" fill="#ffffff18" stroke="#ffffff25"/>
    <text x="89" y="27" text-anchor="middle" fill="#ffffff" font-size="20" font-family="Arial, sans-serif">Admin Only</text>
  </g>
  <g transform="translate(482 242)">
    <rect width="218" height="42" rx="21" fill="#ffffff18" stroke="#ffffff25"/>
    <text x="109" y="27" text-anchor="middle" fill="#ffffff" font-size="20" font-family="Arial, sans-serif">Instant User Picker</text>
  </g>
  <g transform="translate(716 242)">
    <rect width="188" height="42" rx="21" fill="#ffffff18" stroke="#ffffff25"/>
    <text x="94" y="27" text-anchor="middle" fill="#ffffff" font-size="20" font-family="Arial, sans-serif">Switch Back</text>
  </g>

  <rect x="82" y="344" width="1436" height="418" rx="28" fill="#ffffff0c" stroke="#ffffff24"/>

  <rect x="130" y="394" width="398" height="292" rx="26" fill="#ffffff"/>
  <rect x="130" y="394" width="398" height="40" rx="26" fill="#f1f4f8"/>
  <rect x="164" y="448" width="330" height="24" rx="12" fill="#eef2f7"/>
  <rect x="164" y="494" width="298" height="18" rx="9" fill="#dbe4ef"/>
  <rect x="164" y="530" width="298" height="18" rx="9" fill="#dbe4ef"/>
  <rect x="164" y="566" width="298" height="18" rx="9" fill="#dbe4ef"/>
  <rect x="164" y="602" width="298" height="18" rx="9" fill="#dbe4ef"/>
  <text x="329" y="723" text-anchor="middle" fill="#ffffff" font-size="28" font-family="Arial, sans-serif">Internal users list</text>

  <rect x="584" y="394" width="398" height="292" rx="26" fill="#ffffff"/>
  <rect x="622" y="430" width="180" height="44" rx="22" fill="url(#accent)"/>
  <circle cx="650" cy="452" r="10" fill="#fff"/>
  <text x="736" y="460" text-anchor="middle" fill="#ffffff" font-size="24" font-family="Arial, sans-serif" font-weight="700">Switch User</text>
  <rect x="622" y="494" width="214" height="140" rx="24" fill="#ffffff" stroke="#e4d9ef"/>
  <text x="648" y="530" fill="#9b7bb5" font-size="16" font-family="Arial, sans-serif" font-weight="700">SELECT A USER</text>
  <circle cx="650" cy="568" r="10" fill="none" stroke="#9b7bb5" stroke-width="4"/>
  <circle cx="650" cy="606" r="10" fill="none" stroke="#9b7bb5" stroke-width="4"/>
  <text x="678" y="574" fill="#3d2660" font-size="20" font-family="Arial, sans-serif">Marc Demo</text>
  <text x="678" y="612" fill="#3d2660" font-size="20" font-family="Arial, sans-serif">User 1</text>
  <text x="783" y="723" text-anchor="middle" fill="#ffffff" font-size="28" font-family="Arial, sans-serif">Systray user picker</text>

  <rect x="1038" y="394" width="398" height="292" rx="26" fill="#ffffff"/>
  <rect x="1076" y="430" width="176" height="44" rx="22" fill="url(#back)"/>
  <text x="1164" y="460" text-anchor="middle" fill="#ffffff" font-size="24" font-family="Arial, sans-serif" font-weight="700">Switch Back</text>
  <rect x="1276" y="430" width="118" height="44" rx="10" fill="#f4f7fb"/>
  <rect x="1076" y="516" width="280" height="20" rx="10" fill="#dbe4ef"/>
  <rect x="1076" y="556" width="248" height="20" rx="10" fill="#dbe4ef"/>
  <rect x="1076" y="596" width="226" height="20" rx="10" fill="#dbe4ef"/>
  <text x="1237" y="723" text-anchor="middle" fill="#ffffff" font-size="28" font-family="Arial, sans-serif">Return to admin</text>

  <text x="800" y="826" text-anchor="middle" fill="#d9e4f5" font-size="25" font-family="Arial, sans-serif">
    Test permissions, reproduce issues, and review the system exactly as your users see it.
  </text>
</svg>
